  </table>
</section>



<section id="booking" class="booking">
    <h2 class="section-title1">Bestill Time</h2>
    <form action="/bestill-time" method="POST">
  <input 
    type="text" 
    name="navn" 
    placeholder="Navn"
    autocomplete="off"
    required
  >

  <input 
    type="number" 
    name="telefonnummer"
    placeholder="Telefonnummer"
    autocomplete="off"
    required
  >

  <input 
    type="text" 
    name="email"
    placeholder="Epost"
    autocomplete="off"
    required
  >

  <input 
    type="date"
    id="dateInput"
    name="bestillingsdato"
    required
  >

  <input 
    type="time"
    id="timeInput"
    name="bestillingstid"
    autocomplete="off"
    required
  >

  <textarea
    name="kommentar"
    placeholder="Hva trenger du hjelp med?"
    autocomplete="off"
  ></textarea>

  <button type="submit">Bestill time</button>
    </form>
</section>
       
<script src="/javascript/app.js"></script>
<%- include('partials/footer') %> <!-- Inkluderer footer-partialen (uten escaping) -->