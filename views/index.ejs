<%- include('partials/header') %> <!-- Inkluderer header-partialen (uten escaping) -->


<% if (typeof message !== 'undefined' && message) { %> <!-- Hvis serveren har sendt en melding -->
  <div class="notice"><%= message %></div> <!-- Viser meldingen i en meldingsboks -->
<% } %> <!-- Slutt på melding-sjekk -->

<section class="hero1"> <!--Lager en section med klasse hero1-->
  <div class="hero-text1">  <!--Lager en div med klasse hero-text1-->
    <h1>Velkommen</h1> <!--Lager et h1 element-->
    <p>Profesjonell behandling for muskel- og leddplager</p>  <!--Lager et p element-->
    <a href="/bestilling" class="btn1">Bestill time</a>  <!--Lager en lenke til booking-seksjonen av nettsiden-->
  </div>

  <!--Lager et overlay over bildet for å kunne vise kontakt -->
  <div class="hero-overlay">
    <div class="overlay-item">
      <h4><i class="fa fa-phone"></i> Kontakt</h4>
      <p>Telefon: 123 45 678</p>
      <p>E-post: kontakt@naprapat.no</p>
    </div>
    <div class="overlay-item">
      <h4><i class="fa fa-clock-o"></i> Åpningstider</h4>
      <p>Man-Fre: 08:00 - 16:00</p>
    </div>
    <div class="overlay-item">
      <h4><i class="fa fa-map-marker"></i> Lokasjon</h4>
      <p>Adresse, sted</p>
    </div>
  </div>

</section>

<section class="hero">
    <div class="hero-text">
        <h2>Naprapat -navn-</h2>
        <p>Spesialist på muskel- og leddplager. Personlig behandling tilpasset dine behov.</p>
        <button onclick="scrollToBooking()">Bestill time nå</button>
    </div>
    <img src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5" alt="Naprapat">
</section>

<section class="naprapati">
    <h2 class="section-title">Hva er Naprapati?</h2>
    <p class="section-description">Naprapati er en manuell behandlingsform som fokuserer på å diagnostisere og behandle muskel- og leddplager. Behandlingen kombinerer teknikker som massasje, tøyning, mobilisering og manipulasjon for å lindre smerte, forbedre bevegelighet og fremme kroppens naturlige helingsprosess.</p>
</section>
<section id="location" class="location">
    <h2 class="section-title">Vårt lokale</h2>
        <img src="https://images.unsplash.com/photo-1505691723518-36a5ac3be353" alt="Klinikk" class="lokale-bilde">
        <br>
        <button onclick="openMaps()">Se i Google Maps</button>
</section>
<%- include('partials/footer') %> <!-- Inkluderer footer-partialen (uten escaping) -->
