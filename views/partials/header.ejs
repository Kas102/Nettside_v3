<!DOCTYPE html> <!--Sier at dette er et html dokument -->
<html lang="no">    <!--Setter språket på nettsiden til norsk-->
<head>  <!--Åpner head taggen-->
<meta charset="UTF-8">  <!--Setter tegnsetett til utf-8-->
<meta name="viewport" content="width=device-width, initial-scale=1.0">  <!--Responsivitet-->
<title>Naprapat Klinikk</title> <!--Setter tittelen på nettsiden-->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">   <!--Legger til Google Font Poppins-->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
<link rel="stylesheet" href="/styles.css">
</head>
<body>

<nav>                                       <!--Lager en nav-element-->
    <h1>Naprapat Klinikk</h1>               <!--Lager et h1 element som skal være overskrivten på nettsiden-->
    <div class="navigasjon">
         <a href="/index">Hjem</a>  
        <div class="dropdown">
            <a>Om oss</a>
            <div class="dropdown-content">
                <a href="/bestilling">Bestill time</a>
                <a href="#location">Lokasjon</a>
            </div>
        </div>     
<% if (user && user.userId) { %>

  <% if (user.rolle === 'admin') { %>
    <a href="/admin-timer">Mine timer</a>
  <% } else { %>
    <a href="/timer">Mine timer</a>
  <% } %>

  <a class="logout-btn" href="/logout">Logg ut</a>

<% } else { %>

  <a href="/login">Logg inn</a>

<% } %>
    
</nav>                                      <!--Lukker nav-elementet-->